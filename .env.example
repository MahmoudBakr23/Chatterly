# ─── Local Development Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# In production, set these directly on your server (Railway/Render dashboard).

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local PostgreSQL — no password needed for local trust auth
DB_HOST=localhost
DB_PORT=5432
# In production, use the full PgBouncer URL:
# DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true
DATABASE_URL=
# Optional read replica and cache DB URLs (leave blank on free tier if unused)
DATABASE_REPLICA_URL=
CACHE_DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local Redis — install via: brew install redis && brew services start redis
# In production, use your Upstash Redis URL (rediss:// for TLS):
# REDIS_URL=rediss://:[password]@[host]:6379
REDIS_URL=redis://localhost:6379/0

# Rails credentials key (required in production boot)
RAILS_MASTER_KEY=

# ─── Puma concurrency ─────────────────────────────────────────────────────────
# DEV: WEB_CONCURRENCY=0 disables cluster mode — avoids macOS fork-safety crash
# (NSCharacterSet + preload_app! incompatibility on macOS).
# Production: set to number of CPU cores (e.g. WEB_CONCURRENCY=2)
WEB_CONCURRENCY=0
RAILS_MAX_THREADS=3

# ─── Sidekiq ──────────────────────────────────────────────────────────────────
# Number of Sidekiq worker threads. Each thread processes one job at a time.
# Free tier: keep at 5. Scale up with available CPU/RAM.
SIDEKIQ_CONCURRENCY=5

# ─── Email ────────────────────────────────────────────────────────────────────
# Used by Devise for password reset emails (not active yet).
MAILER_FROM=no-reply@chatterly.app
